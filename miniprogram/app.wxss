page {
  min-height: 100%;
  background: #f6f7fb;
  color: #172033;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 32rpx 64rpx;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 20rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.18);
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 18rpx;
  background: #ffffff;
  color: #0f172a;
  border: 2rpx solid #d8deea;
  font-size: 30rpx;
  font-weight: 600;
}

.muted {
  color: #667085;
}

.section-title {
  margin: 44rpx 0 20rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
}

.card {
  background: #ffffff;
  border: 2rpx solid #e6eaf2;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.05);
}
