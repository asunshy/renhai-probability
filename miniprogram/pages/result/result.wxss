.result-hero {
  padding: 44rpx 0 34rpx;
}

.region {
  color: #2563eb;
  font-size: 28rpx;
  font-weight: 800;
}

.number {
  margin-top: 18rpx;
  color: #0f172a;
  font-size: 68rpx;
  font-weight: 900;
  line-height: 1.1;
}

.probability {
  margin-top: 14rpx;
  color: #667085;
  font-size: 28rpx;
}

.comment {
  padding: 30rpx;
  background: #111827;
  border-color: #111827;
}

.comment-title {
  color: #93c5fd;
  font-size: 26rpx;
  font-weight: 800;
}

.comment-text {
  margin-top: 16rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.5;
}

.summary-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.summary-card {
  flex: 1;
  min-height: 180rpx;
  padding: 26rpx;
  box-sizing: border-box;
}

.summary-label {
  color: #667085;
  font-size: 24rpx;
  font-weight: 700;
}

.summary-value {
  margin-top: 12rpx;
  color: #0f172a;
  font-size: 36rpx;
  font-weight: 900;
}

.summary-copy {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
}

.employment-card {
  margin-top: 24rpx;
  padding: 28rpx;
  background: #eff6ff;
  border-color: #bfdbfe;
}

.employment-title {
  color: #1d4ed8;
  font-size: 25rpx;
  font-weight: 800;
}

.employment-main {
  margin-top: 14rpx;
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.45;
}

.employment-copy {
  margin-top: 12rpx;
  color: #475569;
  font-size: 23rpx;
  line-height: 1.55;
}

.factor-list {
  padding: 0 28rpx;
}

.factor-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 102rpx;
  border-bottom: 2rpx solid #eef2f7;
}

.factor-row:last-child {
  border-bottom: 0;
}

.factor-name {
  color: #172033;
  font-size: 28rpx;
  font-weight: 700;
}

.factor-source {
  margin-top: 8rpx;
  color: #7c8798;
  font-size: 23rpx;
}

.factor-rate {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 900;
}

.warning {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 26rpx;
  line-height: 1.6;
}

.notes-button,
.retry-button {
  margin-top: 24rpx;
}

.empty-title {
  margin-top: 120rpx;
  font-size: 44rpx;
  font-weight: 900;
  color: #0f172a;
}

.empty-copy {
  margin: 18rpx 0 40rpx;
  color: #667085;
  font-size: 28rpx;
  line-height: 1.6;
}
